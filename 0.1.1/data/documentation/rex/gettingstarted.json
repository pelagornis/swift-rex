{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","identifier":{"url":"doc:\/\/Rex\/documentation\/Rex\/GettingStarted","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This guide will walk you through setting up Swift-Rex in your project and creating a simple counter app to demonstrate the basic concepts.","type":"text"}]},{"level":2,"type":"heading","text":"Installation","anchor":"Installation"},{"level":3,"type":"heading","text":"Swift Package Manager","anchor":"Swift-Package-Manager"},{"type":"paragraph","inlineContent":[{"text":"Add Swift-Rex to your project using Swift Package Manager:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, go to "},{"type":"strong","inlineContent":[{"text":"File","type":"text"}]},{"type":"text","text":" > "},{"type":"strong","inlineContent":[{"type":"text","text":"Add Package Dependencies"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter the repository URL: "},{"type":"codeVoice","code":"https:\/\/github.com\/pelagornis\/swift-rex.git"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the version you want to use"}]}]},{"content":[{"inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"type":"text","text":"Add Package"}],"type":"strong"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":3,"type":"heading","text":"Manual Installation","anchor":"Manual-Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you prefer to add it manually, add this to your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}]},{"syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/pelagornis\/swift-rex.git\", from: \"vTag\")","]"],"type":"codeListing"},{"level":2,"type":"heading","text":"Your First Swift-Rex App","anchor":"Your-First-Swift-Rex-App"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s create a simple counter app to demonstrate the basic concepts."}]},{"level":3,"type":"heading","text":"1. Define Your State","anchor":"1-Define-Your-State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, define what your app’s state looks like:"}]},{"syntax":"swift","code":["import Rex","","struct AppState: StateType {","    var count: Int = 0","    var isLoading: Bool = false","    var errorMessage: String? = nil","    var lastUpdated: Date = Date()","}"],"type":"codeListing"},{"level":3,"type":"heading","text":"2. Define Your Actions","anchor":"2-Define-Your-Actions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Next, define the actions that can change your state:"}]},{"syntax":"swift","code":["enum AppAction: ActionType {","    case increment","    case decrement","    case reset","    case setCount(Int)","    case loadFromServer","    case loadedFromServer(Int)","    case showError(String?)","    case clearError","}"],"type":"codeListing"},{"level":3,"type":"heading","text":"3. Create Your Reducer","anchor":"3-Create-Your-Reducer"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a reducer that handles state changes:"}]},{"syntax":"swift","code":["struct AppReducer: Reducer {","    func reduce(state: inout AppState, action: AppAction) -> [Effect<AppAction>] {","        switch action {","        case .increment:","            state.count += 1","            state.lastUpdated = Date()","            return [.none]","","        case .decrement:","            state.count -= 1","            state.lastUpdated = Date()","            return [.none]","","        case .reset:","            state.count = 0","            state.lastUpdated = Date()","            return [.none]","","        case .setCount(let count):","            state.count = count","            state.lastUpdated = Date()","            return [.none]","","        case .loadFromServer:","            state.isLoading = true","            state.errorMessage = nil","            return [","                Effect { emitter in","                    try? await Task.sleep(nanoseconds: 1_000_000_000)","                    let randomCount = Int.random(in: 1...100)","                    await emitter.send(.loadedFromServer(randomCount))","                }","            ]","","        case .loadedFromServer(let count):","            state.count = count","            state.isLoading = false","            state.lastUpdated = Date()","            return [.none]","","        case .showError(let message):","            state.errorMessage = message","            state.isLoading = false","            state.lastUpdated = Date()","            return [.none]","","        case .clearError:","            state.errorMessage = nil","            state.lastUpdated = Date()","            return [.none]","        }","    }","}"],"type":"codeListing"},{"level":3,"type":"heading","text":"4. Create Your Store","anchor":"4-Create-Your-Store"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a store that manages your state:"}]},{"syntax":"swift","code":["let store = Store(","    initialState: AppState(),","    reducer: AppReducer()",") {","    LoggingMiddleware()","}"],"type":"codeListing"},{"level":3,"type":"heading","text":"5. Use in SwiftUI","anchor":"5-Use-in-SwiftUI"},{"type":"paragraph","inlineContent":[{"text":"Create a SwiftUI view that uses your store:","type":"text"}]},{"syntax":"swift","code":["import SwiftUI","import Rex","","struct ContentView: View {","    @StateObject var store: ObservableStore<AppReducer>","","    var body: some View {","        VStack(spacing: 20) {","            Text(\"Count: \\(store.state.count)\")","                .font(.title)","","            HStack(spacing: 12) {","                Button(\"+1\") { store.send(.increment) }","                Button(\"-1\") { store.send(.decrement) }","            }","","            Button(\"Reset\") { store.send(.reset) }","","            Button(\"Load from Server\") {","                store.send(.loadFromServer)","            }","            .disabled(store.state.isLoading)","","            if store.state.isLoading {","                ProgressView(\"Loading...\")","            }","","            if let error = store.state.errorMessage {","                Text(error)","                    .foregroundColor(.red)","                    .onTapGesture {","                        store.send(.clearError)","                    }","            }","        }","        .padding()","    }","}","","@main","struct MyApp: App {","    let store = Store(","        initialState: AppState(),","        reducer: AppReducer()","    )","","    var body: some Scene {","        WindowGroup {","            ContentView(store: ObservableStore(store: store))","        }","    }","}"],"type":"codeListing"},{"level":3,"type":"heading","text":"6. Use in UIKit","anchor":"6-Use-in-UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For UIKit, you can use the store directly:"}]},{"syntax":"swift","code":["import UIKit","import Rex","","class ViewController: UIViewController {","    private let store: Store<AppReducer>","    private let label = UILabel()","    private let incrementButton = UIButton(type: .system)","    private let decrementButton = UIButton(type: .system)","","    init(store: Store<AppReducer>) {","        self.store = store","        super.init(nibName: nil, bundle: nil)","","        store.subscribe { [weak self] newState in","            Task { @MainActor in","                self?.updateUI(with: newState)","            }","        }","    }","","    required init?(coder: NSCoder) { fatalError() }","","    override func viewDidLoad() {","        super.viewDidLoad()","        setupUI()","        updateUI(with: store.state)","    }","","    private func setupUI() {","        \/\/ Setup your UI elements here","        incrementButton.addTarget(self, action: #selector(increment), for: .touchUpInside)","        decrementButton.addTarget(self, action: #selector(decrement), for: .touchUpInside)","    }","","    private func updateUI(with state: AppState) {","        label.text = \"Count: \\(state.count)\"","    }","","    @objc private func increment() { store.dispatch(.increment) }","    @objc private func decrement() { store.dispatch(.decrement) }","}"],"type":"codeListing"},{"level":2,"type":"heading","text":"Next Steps","anchor":"Next-Steps"},{"type":"paragraph","inlineContent":[{"text":"Now that you have a basic understanding of Swift-Rex, explore these topics:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Rex\/documentation\/Rex\/BasicConcepts","type":"reference"},{"text":" - Learn about the core concepts","type":"text"}]}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Rex\/documentation\/Rex\/StateManagement"},{"type":"text","text":" - Understand state management patterns"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Rex\/documentation\/Rex\/SwiftUIIntegration","isActive":true},{"text":" - Deep dive into SwiftUI integration","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"doc:UIKitIntegration"},{"type":"text","text":" - Learn about UIKit integration"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Rex\/documentation\/Rex\/EventBus","isActive":true},{"type":"text","text":" - Explore cross-component communication"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"abstract":[{"type":"text","text":"Learn how to integrate Swift-Rex into your iOS app and create your first state management setup."}],"hierarchy":{"paths":[["doc:\/\/Rex\/documentation\/Rex"]]},"metadata":{"role":"article","title":"Getting Started","roleHeading":"Article","modules":[{"name":"Rex"}]},"sections":[],"variants":[{"paths":["\/documentation\/rex\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Rex/documentation/Rex/StateManagement":{"identifier":"doc:\/\/Rex\/documentation\/Rex\/StateManagement","role":"article","kind":"article","abstract":[{"type":"text","text":"Learn how to effectively manage application state with Swift-Rex."}],"type":"topic","title":"State Management","url":"\/documentation\/rex\/statemanagement"},"doc://Rex/documentation/Rex/BasicConcepts":{"type":"topic","role":"article","url":"\/documentation\/rex\/basicconcepts","abstract":[{"text":"Learn the fundamental concepts that make up the Swift-Rex architecture.","type":"text"}],"title":"Basic Concepts","identifier":"doc:\/\/Rex\/documentation\/Rex\/BasicConcepts","kind":"article"},"doc://Rex/documentation/Rex":{"kind":"symbol","abstract":[],"type":"topic","identifier":"doc:\/\/Rex\/documentation\/Rex","title":"Rex","role":"collection","url":"\/documentation\/rex"},"doc://Rex/documentation/Rex/EventBus":{"identifier":"doc:\/\/Rex\/documentation\/Rex\/EventBus","role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"EventBus"}],"abstract":[],"kind":"symbol","title":"EventBus","url":"\/documentation\/rex\/eventbus","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"EventBus"}]},"doc://Rex/documentation/Rex/SwiftUIIntegration":{"identifier":"doc:\/\/Rex\/documentation\/Rex\/SwiftUIIntegration","role":"article","kind":"article","abstract":[{"type":"text","text":"Learn how to integrate Swift-Rex with SwiftUI applications."}],"type":"topic","title":"SwiftUI Integration","url":"\/documentation\/rex\/swiftuiintegration"}}}