{"sections":[],"identifier":{"url":"doc:\/\/Rex\/documentation\/Rex\/StateManagement","interfaceLanguage":"swift"},"kind":"article","primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"State management is the core of any Swift-Rex application. Understanding how to structure and manage your state effectively is crucial for building maintainable and scalable applications."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"State-Structure","text":"State Structure"},{"level":3,"type":"heading","anchor":"Single-State-Tree","text":"Single State Tree"},{"inlineContent":[{"type":"text","text":"Swift-Rex uses a single state tree that represents the entire state of your application. This makes it easy to track changes and debug issues."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct AppState: StateType {","    \/\/ User state","    var user: User?","    var isAuthenticated: Bool = false","","    \/\/ UI state","    var isLoading: Bool = false","    var errorMessage: String? = nil","","    \/\/ Feature state","    var counter: CounterState = CounterState()","    var todo: TodoState = TodoState()","    var settings: SettingsState = SettingsState()","","    \/\/ App state","    var lastUpdated: Date = Date()","}"]},{"level":3,"type":"heading","anchor":"Nested-State","text":"Nested State"},{"inlineContent":[{"type":"text","text":"Break down your state into smaller, focused pieces:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct CounterState {","    var count: Int = 0","    var history: [Int] = []","}","","struct TodoState {","    var todos: [Todo] = []","    var filter: TodoFilter = .all","    var isLoading: Bool = false","}","","struct SettingsState {","    var theme: Theme = .light","    var notifications: Bool = true","    var language: Language = .english","}"]},{"level":2,"type":"heading","anchor":"State-Updates","text":"State Updates"},{"level":3,"type":"heading","anchor":"Immutable-Updates","text":"Immutable Updates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always create new state rather than modifying existing state:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ ❌ Wrong - Direct mutation","state.count += 1","","\/\/ ✅ Correct - Create new state","state.count = state.count + 1"]},{"level":3,"type":"heading","text":"Batch Updates","anchor":"Batch-Updates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When updating multiple properties, do it in a single action:"}]},{"type":"codeListing","syntax":"swift","code":["case .userLoggedIn(let user):","    state.user = user","    state.isAuthenticated = true","    state.errorMessage = nil","    state.lastUpdated = Date()","    return [.none]"]},{"level":2,"type":"heading","text":"State Normalization","anchor":"State-Normalization"},{"level":3,"type":"heading","text":"Normalized Data","anchor":"Normalized-Data"},{"type":"paragraph","inlineContent":[{"text":"Store related data in a normalized structure for better performance:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct AppState: StateType {","    \/\/ Normalized entities","    var users: [String: User] = [:]","    var posts: [String: Post] = [:]","    var comments: [String: Comment] = [:]","","    \/\/ References","    var currentUserId: String?","    var selectedPostId: String?","","    \/\/ UI state","    var isLoading: Bool = false","    var errorMessage: String? = nil","}"]},{"level":3,"type":"heading","text":"Benefits of Normalization","anchor":"Benefits-of-Normalization"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Performance"}],"type":"strong"},{"text":": Faster lookups and updates","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Consistency","type":"text"}],"type":"strong"},{"type":"text","text":": Single source of truth for each entity"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Memory"}]},{"type":"text","text":": Reduced memory usage"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Updates"}]},{"type":"text","text":": Easier to update related data"}]}]}]},{"level":2,"type":"heading","anchor":"State-Composition","text":"State Composition"},{"level":3,"type":"heading","anchor":"Combining-Reducers","text":"Combining Reducers"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Split your reducer into smaller, focused reducers:"}]},{"code":["struct AppReducer: Reducer {","    func reduce(state: inout AppState, action: AppAction) -> [Effect<AppAction>] {","        switch action {","        case let .counter(action):","            return counterReducer.reduce(state: &state.counter, action: action)","","        case let .todo(action):","            return todoReducer.reduce(state: &state.todo, action: action)","","        case let .settings(action):","            return settingsReducer.reduce(state: &state.settings, action: action)","","        case .userLoggedIn(let user):","            state.user = user","            state.isAuthenticated = true","            return [.none]","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"Action-Composition","text":"Action Composition"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use associated values to compose actions:"}]},{"code":["enum AppAction: ActionType {","    case counter(CounterAction)","    case todo(TodoAction)","    case settings(SettingsAction)","    case user(UserAction)","}","","enum CounterAction: ActionType {","    case increment","    case decrement","    case reset","}","","enum TodoAction: ActionType {","    case add(String)","    case remove(String)","    case toggle(String)","    case setFilter(TodoFilter)","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"State-Persistence","text":"State Persistence"},{"level":3,"type":"heading","anchor":"Saving-State","text":"Saving State"},{"type":"paragraph","inlineContent":[{"text":"Persist important state to disk:","type":"text"}]},{"code":["struct AppReducer: Reducer {","    func reduce(state: inout AppState, action: AppAction) -> [Effect<AppAction>] {","        switch action {","        case .userLoggedIn(let user):","            state.user = user","            state.isAuthenticated = true","            return [","                Effect { emitter in","                    \/\/ Save user to disk","                    try await UserDefaults.standard.setValue(","                        user.id,","                        forKey: \"currentUserId\"","                    )","                    await emitter.send(.userSaved)","                }","            ]","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"Loading-State","text":"Loading State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Load persisted state on app launch:"}]},{"code":["struct AppReducer: Reducer {","    func reduce(state: inout AppState, action: AppAction) -> [Effect<AppAction>] {","        switch action {","        case .loadPersistedState:","            return [","                Effect { emitter in","                    if let userId = UserDefaults.standard.string(forKey: \"currentUserId\") {","                        let user = try await UserService.fetchUser(id: userId)","                        await emitter.send(.userLoaded(user))","                    }","                }","            ]","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"State-Validation","text":"State Validation"},{"level":3,"type":"heading","anchor":"Input-Validation","text":"Input Validation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Validate state changes in your reducer:"}]},{"code":["case .setCount(let count):","    guard count >= 0 else {","        state.errorMessage = \"Count cannot be negative\"","        return [.none]","    }","    state.count = count","    state.lastUpdated = Date()","    return [.none]"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"State-Constraints","text":"State Constraints"},{"type":"paragraph","inlineContent":[{"text":"Enforce business rules in your state:","type":"text"}]},{"code":["struct AppState: StateType {","    var count: Int = 0 {","        didSet {","            \/\/ Ensure count never goes below 0","            if count < 0 {","                count = 0","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Performance-Optimization","text":"Performance Optimization"},{"level":3,"type":"heading","anchor":"Selective-Updates","text":"Selective Updates"},{"type":"paragraph","inlineContent":[{"text":"Only update what has changed:","type":"text"}]},{"code":["case .updateUserProfile(let profile):","    \/\/ Only update if profile actually changed","    if state.user?.profile != profile {","        state.user?.profile = profile","        state.lastUpdated = Date()","    }","    return [.none]"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"Computed-Properties","text":"Computed Properties"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use computed properties for derived state:"}]},{"code":["extension AppState {","    var completedTodos: [Todo] {","        todos.filter { $0.isCompleted }","    }","","    var incompleteTodos: [Todo] {","        todos.filter { !$0.isCompleted }","    }","","    var todoCount: Int {","        todos.count","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Best-Practices","text":"Best Practices"},{"level":3,"type":"heading","anchor":"1-Keep-State-Minimal","text":"1. Keep State Minimal"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only store what you need:"}]},{"code":["\/\/ ❌ Don't store derived data","struct AppState {","    var todos: [Todo] = []","    var completedTodos: [Todo] = [] \/\/ Redundant","}","","\/\/ ✅ Store only source data","struct AppState {","    var todos: [Todo] = []","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"2-Use-Descriptive-Names","text":"2. Use Descriptive Names"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Make your state properties self-documenting:"}]},{"code":["\/\/ ❌ Unclear","var flag: Bool = false","","\/\/ ✅ Clear","var isUserLoggedIn: Bool = false"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"3-Group-Related-State","text":"3. Group Related State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep related properties together:"}]},{"code":["struct AppState {","    \/\/ Authentication","    var user: User?","    var isAuthenticated: Bool = false","    var authToken: String?","","    \/\/ UI State","    var isLoading: Bool = false","    var errorMessage: String? = nil","    var currentTab: Tab = .home","","    \/\/ Feature State","    var counter: CounterState = CounterState()","    var todo: TodoState = TodoState()","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"4-Handle-Loading-States","text":"4. Handle Loading States"},{"type":"paragraph","inlineContent":[{"text":"Always track loading states for async operations:","type":"text"}]},{"code":["case .loadUser:","    state.isLoading = true","    state.errorMessage = nil","    return [","        Effect { emitter in","            let user = try await UserService.fetchUser()","            await emitter.send(.userLoaded(user))","        }","    ]"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"5-Error-Handling","text":"5. Error Handling"},{"type":"paragraph","inlineContent":[{"text":"Provide meaningful error messages:","type":"text"}]},{"code":["case .loadUserFailed(let error):","    state.isLoading = false","    state.errorMessage = \"Failed to load user: \\(error.localizedDescription)\"","    return [.none]"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Next-Steps","text":"Next Steps"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that you understand state management, explore:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Rex\/documentation\/Rex\/Store","isActive":true,"type":"reference"},{"text":" - Learn about the Store implementation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Rex\/documentation\/Rex\/Reducer"},{"type":"text","text":" - Understand Reducer patterns"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Rex\/documentation\/Rex\/Effect","type":"reference"},{"text":" - Handle side effects","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"doc:BestPractices"},{"type":"text","text":" - Advanced patterns and tips"}]}]}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Learn how to effectively manage application state with Swift-Rex."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/rex\/statemanagement"]}],"hierarchy":{"paths":[["doc:\/\/Rex\/documentation\/Rex"]]},"metadata":{"modules":[{"name":"Rex"}],"roleHeading":"Article","role":"article","title":"State Management"},"references":{"doc://Rex/documentation/Rex/Effect":{"kind":"symbol","type":"topic","title":"Effect","url":"\/documentation\/rex\/effect","abstract":[{"type":"text","text":"A struct that represents a side effect that can be executed by the store."}],"role":"symbol","navigatorTitle":[{"text":"Effect","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Effect","kind":"identifier"}],"identifier":"doc:\/\/Rex\/documentation\/Rex\/Effect"},"doc://Rex/documentation/Rex/Store":{"type":"topic","identifier":"doc:\/\/Rex\/documentation\/Rex\/Store","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Store","kind":"identifier"}],"url":"\/documentation\/rex\/store","navigatorTitle":[{"text":"Store","kind":"identifier"}],"abstract":[],"kind":"symbol","title":"Store"},"doc://Rex/documentation/Rex":{"kind":"symbol","abstract":[],"type":"topic","identifier":"doc:\/\/Rex\/documentation\/Rex","title":"Rex","role":"collection","url":"\/documentation\/rex"},"doc://Rex/documentation/Rex/Reducer":{"url":"\/documentation\/rex\/reducer","title":"Reducer","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Reducer"}],"abstract":[{"type":"text","text":"A protocol that defines the core logic for transforming state based on actions."}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reducer"}],"role":"symbol","identifier":"doc:\/\/Rex\/documentation\/Rex\/Reducer","type":"topic"}}}