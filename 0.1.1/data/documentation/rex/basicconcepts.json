{"kind":"article","abstract":[{"text":"Learn the fundamental concepts that make up the Swift-Rex architecture.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/rex\/basicconcepts"]}],"hierarchy":{"paths":[["doc:\/\/Rex\/documentation\/Rex"]]},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Swift-Rex is built around a few core concepts that work together to provide a predictable and manageable state management system. Understanding these concepts is key to building effective applications with Swift-Rex.","type":"text"}]},{"text":"State","level":2,"type":"heading","anchor":"State"},{"type":"paragraph","inlineContent":[{"text":"State represents the current condition of your application at any point in time. It’s the single source of truth for your app’s data.","type":"text"}]},{"text":"Key Characteristics","level":3,"type":"heading","anchor":"Key-Characteristics"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Immutable"}]},{"type":"text","text":": State should never be modified directly"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Serializable"}]},{"type":"text","text":": State can be saved and restored"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Predictable"}]},{"text":": Given the same inputs, state changes are always the same","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Observable"}]},{"text":": Changes to state trigger UI updates","type":"text"}]}]}]},{"text":"Example","level":3,"type":"heading","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["struct AppState: StateType {","    var count: Int = 0","    var isLoading: Bool = false","    var errorMessage: String? = nil","    var lastUpdated: Date = Date()","    var user: User?","}"]},{"text":"Actions","level":2,"type":"heading","anchor":"Actions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Actions describe what happened in your application. They are the only way to change state."}]},{"text":"Key Characteristics","level":3,"type":"heading","anchor":"Key-Characteristics"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Descriptive"}],"type":"strong"},{"text":": Actions clearly describe what happened","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Immutable"}]},{"type":"text","text":": Actions contain only the data needed to describe the event"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Serializable"}]},{"text":": Actions can be logged and replayed","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Type-Safe"}]},{"type":"text","text":": Actions are strongly typed"}],"type":"paragraph"}]}]},{"text":"Example","level":3,"type":"heading","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["enum AppAction: ActionType {","    \/\/ User interactions","    case increment","    case decrement","    case setCount(Int)","    ","    \/\/ Async operations","    case loadUser","    case userLoaded(User)","    case loadFailed(String)","    ","    \/\/ UI state","    case showLoading","    case hideLoading","    case setError(String?)","}"]},{"text":"Reducers","level":2,"type":"heading","anchor":"Reducers"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reducers are pure functions that take the current state and an action, then return a new state and any effects."}]},{"text":"Key Principles","level":3,"type":"heading","anchor":"Key-Principles"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Pure Functions","type":"text"}]},{"type":"text","text":": Reducers have no side effects"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Predictable"}],"type":"strong"},{"text":": Same state + action always produces same result","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Immutable","type":"text"}]},{"text":": Always return new state, never modify existing state","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Composable"}]},{"type":"text","text":": Reducers can be combined and split"}],"type":"paragraph"}]}]},{"text":"Example","level":3,"type":"heading","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["struct AppReducer: Reducer {","    func reduce(state: inout AppState, action: AppAction) -> [Effect<AppAction>] {","        switch action {","        case .increment:","            state.count += 1","            state.lastUpdated = Date()","            return [.none]","            ","        case .loadUser:","            state.isLoading = true","            state.errorMessage = nil","            return [","                Effect { emitter in","                    let user = try await UserService.fetchUser()","                    await emitter.send(.userLoaded(user))","                }","            ]","            ","        case .userLoaded(let user):","            state.user = user","            state.isLoading = false","            state.lastUpdated = Date()","            return [.none]","        }","    }","}"]},{"text":"Store","level":2,"type":"heading","anchor":"Store"},{"type":"paragraph","inlineContent":[{"text":"The store is the central coordinator that holds the state, dispatches actions, and manages effects.","type":"text"}]},{"text":"Responsibilities","level":3,"type":"heading","anchor":"Responsibilities"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"State Management"}]},{"type":"text","text":": Holds the current application state"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Action Dispatching"}]},{"type":"text","text":": Processes actions through the reducer"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Effect Execution","type":"text"}]},{"type":"text","text":": Runs side effects and async operations"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Subscription Management","type":"text"}]},{"type":"text","text":": Notifies subscribers of state changes"}]}]}]},{"text":"Example","level":3,"type":"heading","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["let store = Store(","    initialState: AppState(),","    reducer: AppReducer()",") {","    LoggingMiddleware()","}","","\/\/ Subscribe to state changes","store.subscribe { newState in","    print(\"State updated: \\(newState)\")","}","","\/\/ Dispatch actions","store.dispatch(.increment)","store.dispatch(.loadUser)"]},{"type":"heading","level":2,"anchor":"Effects","text":"Effects"},{"inlineContent":[{"text":"Effects represent side effects or asynchronous operations that can’t be performed in the reducer.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Use-Cases","text":"Use Cases"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Network Requests","type":"text"}],"type":"strong"},{"text":": API calls and data fetching","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"File Operations","type":"text"}],"type":"strong"},{"text":": Reading and writing files","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Timers"}]},{"text":": Scheduled operations","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Device Services","type":"text"}]},{"type":"text","text":": Camera, location, etc."}]}]}],"type":"unorderedList"},{"type":"heading","level":3,"anchor":"Example","text":"Example"},{"code":["\/\/ Network request effect","Effect { emitter in","    let data = try await URLSession.shared.data(from: url)","    let response = try JSONDecoder().decode(User.self, from: data.0)","    await emitter.send(.userLoaded(response))","}","","\/\/ Timer effect","Effect { emitter in","    for await _ in Timer.publish(every: 1, on: .main, in: .common).autoconnect() {","        await emitter.send(.timerTick)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Data-Flow","text":"Data Flow"},{"inlineContent":[{"type":"text","text":"Swift-Rex follows a unidirectional data flow:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"User Interaction","type":"text"}]},{"type":"text","text":": User performs an action (e.g., taps a button)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Action Dispatch"}],"type":"strong"},{"text":": An action is dispatched to the store","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Middleware Processing","type":"text"}]},{"text":": Actions pass through middleware (logging, analytics, etc.)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Reducer Processing"}]},{"text":": The reducer processes the action and updates state","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Effect Execution"}],"type":"strong"},{"type":"text","text":": Any effects returned by the reducer are executed"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"State Update"}]},{"type":"text","text":": The store updates its state"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"UI Update"}]},{"type":"text","text":": Subscribers are notified and the UI updates"}]}]}],"type":"orderedList"},{"type":"heading","level":3,"anchor":"Visual-Flow","text":"Visual Flow"},{"code":["User Action → Action Dispatch → Middleware → Reducer → Effects → State Update → UI Update"],"type":"codeListing","syntax":null},{"type":"heading","level":2,"anchor":"Benefits","text":"Benefits"},{"inlineContent":[{"type":"text","text":"This architecture provides several key benefits:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Predictability"}]},{"type":"text","text":": State changes are predictable and traceable"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Debugging"}]},{"text":": Easy to debug with action logging and time travel","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Testing"}],"type":"strong"},{"text":": Pure functions are easy to test","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Performance"}]},{"text":": Efficient updates and minimal re-renders","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Scalability","type":"text"}],"type":"strong"},{"text":": Architecture scales well with app complexity","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Maintainability"}],"type":"strong"},{"type":"text","text":": Clear separation of concerns"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Next-Steps","text":"Next Steps"},{"inlineContent":[{"type":"text","text":"Now that you understand the basic concepts, explore:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Rex\/documentation\/Rex\/StateManagement"},{"text":" - Learn about state management patterns","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Rex\/documentation\/Rex\/Store","isActive":true},{"type":"text","text":" - Deep dive into the Store"}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Rex\/documentation\/Rex\/Reducer"},{"type":"text","text":" - Learn about Reducer patterns"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Rex\/documentation\/Rex\/Effect","isActive":true,"type":"reference"},{"type":"text","text":" - Understand Effects and side effects"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"identifier":{"url":"doc:\/\/Rex\/documentation\/Rex\/BasicConcepts","interfaceLanguage":"swift"},"metadata":{"title":"Basic Concepts","role":"article","modules":[{"name":"Rex"}],"roleHeading":"Article"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://Rex/documentation/Rex/Reducer":{"url":"\/documentation\/rex\/reducer","title":"Reducer","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Reducer"}],"abstract":[{"type":"text","text":"A protocol that defines the core logic for transforming state based on actions."}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Reducer"}],"role":"symbol","identifier":"doc:\/\/Rex\/documentation\/Rex\/Reducer","type":"topic"},"doc://Rex/documentation/Rex":{"kind":"symbol","abstract":[],"type":"topic","identifier":"doc:\/\/Rex\/documentation\/Rex","title":"Rex","role":"collection","url":"\/documentation\/rex"},"doc://Rex/documentation/Rex/StateManagement":{"identifier":"doc:\/\/Rex\/documentation\/Rex\/StateManagement","role":"article","kind":"article","abstract":[{"type":"text","text":"Learn how to effectively manage application state with Swift-Rex."}],"type":"topic","title":"State Management","url":"\/documentation\/rex\/statemanagement"},"doc://Rex/documentation/Rex/Store":{"type":"topic","identifier":"doc:\/\/Rex\/documentation\/Rex\/Store","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Store","kind":"identifier"}],"url":"\/documentation\/rex\/store","navigatorTitle":[{"text":"Store","kind":"identifier"}],"abstract":[],"kind":"symbol","title":"Store"},"doc://Rex/documentation/Rex/Effect":{"kind":"symbol","type":"topic","title":"Effect","url":"\/documentation\/rex\/effect","abstract":[{"type":"text","text":"A struct that represents a side effect that can be executed by the store."}],"role":"symbol","navigatorTitle":[{"text":"Effect","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Effect","kind":"identifier"}],"identifier":"doc:\/\/Rex\/documentation\/Rex\/Effect"}}}